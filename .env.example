# Copy to .env.local for development, or .env for production.
# All values here are optional — sensible defaults apply if unset.

# Where SQLite stores the database file.
# Defaults to ./data.db in the project root.
# Set this to a persistent disk path in production (e.g. /var/lib/aa-arts/data.db).
# DATA_DB_PATH=./data.db

# Standard Node env. Set to "production" when running `npm start`.
# Affects cookie `secure` flag — production cookies require HTTPS.
# NODE_ENV=development
